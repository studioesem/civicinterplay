---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORY_LABEL } from '../content/config';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-AU', { year: 'numeric', month: 'long' });
---
<BaseLayout
  title="Reading"
  description="The Think half of Civic Interplay. Essays, notes, and field reports on civic agencies, planetary citizenship, and co-intelligent technologies."
>
  <main class="container reading">
    <header class="reading-header">
      <p class="reading-eyebrow">Civic Interplay / Think</p>
      <h1>Reading</h1>
      <p class="reading-intro">
        Essays, notes, and field reports. Some long, some short. All work in
        progress &mdash; you are welcome to disagree with any of it.
      </p>
    </header>

    <ul class="reading-list">
      {posts.map((p) => (
        <li class="reading-row">
          <a href={`/${p.slug}/`} class={`reading-link ${p.data.primaryCategory ? `cat-${p.data.primaryCategory}` : ''}`}>
            <time class="reading-date" datetime={p.data.publishedAt.toISOString().slice(0, 10)}>
              {formatDate(p.data.publishedAt)}
            </time>
            <div class="reading-body">
              {p.data.primaryCategory && (
                <div class="reading-tag">{CATEGORY_LABEL[p.data.primaryCategory]}</div>
              )}
              <h2>{p.data.title}</h2>
              {p.data.excerpt && <p class="reading-excerpt">{p.data.excerpt}</p>}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>

  <style>
    .reading {
      padding: 3rem 2rem 4rem;
      max-width: 880px;
    }

    .reading-header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 2px solid var(--border);
    }

    .reading-eyebrow {
      font-family: var(--heading);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-faint);
      margin-bottom: 0.6rem;
    }

    .reading-header h1 {
      font-family: var(--heading);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 300;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 0.6rem;
    }

    .reading-intro {
      font-family: var(--body);
      font-size: 0.95rem;
      font-style: italic;
      color: var(--text-dim);
      max-width: 56ch;
    }

    .reading-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .reading-row {
      border-top: 1px solid var(--border-light);
    }

    .reading-row:last-child {
      border-bottom: 1px solid var(--border-light);
    }

    .reading-link {
      display: grid;
      grid-template-columns: 9rem 1fr;
      gap: 1.5rem;
      padding: 1.6rem 0.5rem;
      align-items: baseline;
      text-decoration: none;
      color: inherit;
      transition: padding-left 0.25s ease, background 0.25s ease;
    }

    .reading-link:hover {
      padding-left: 1.25rem;
      background: rgba(125, 80, 189, 0.04);
    }

    .reading-date {
      font-family: var(--heading);
      font-size: 0.78rem;
      font-weight: 400;
      color: var(--text-faint);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .reading-tag {
      font-family: var(--heading);
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 0.5rem;
    }

    .reading-link.cat-introduction .reading-tag { color: var(--purple); }
    .reading-link.cat-training-grounds .reading-tag { color: var(--terracotta); }
    .reading-link.cat-the-guides .reading-tag { color: var(--periwinkle); }
    .reading-link.cat-work-sheets .reading-tag { color: var(--forest); }
    .reading-link.cat-the-portals .reading-tag { color: var(--pink); }

    .reading-body h2 {
      font-family: var(--heading);
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.3;
      margin-bottom: 0.5rem;
      transition: color 0.25s ease;
    }

    .reading-link:hover .reading-body h2 {
      color: var(--purple);
    }

    .reading-excerpt {
      font-family: var(--body);
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.6;
      color: var(--text-dim);
      max-width: 65ch;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    @media (max-width: 640px) {
      .reading {
        padding: 2rem 1rem 3rem;
      }
      .reading-link {
        grid-template-columns: 1fr;
        gap: 0.5rem;
      }
      .reading-link:hover {
        padding-left: 0.5rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .reading-link,
      .reading-link:hover .reading-body h2 {
        transition: none;
      }
    }
  </style>
</BaseLayout>
